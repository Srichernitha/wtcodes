script.js
const qtyInputs =document.querySelectorAll(".qty");
const itemTotals =document.querySelectorAll(".itemTotal");
const subtotalText =document.getElementById("subtotal");
const deliveryText =document.getElementById("delivery");
const grandText =document.getElementById("grandtotal");
const hiddenTotal =document.getElementById("hiddenTotal");
qtyInputs.forEach((input,index)=>{
    input.addEventListener("input",()=>{
        calculateTotal();
    });
});
function calculateTotal(){
    let subtotal = 0;
    qtyInputs.forEach((input,index)=>{
        let quantity =parseInt(input.value) || 0;
        let price =parseInt(input.dataset.price);
        let total =quantity * price;
        itemTotals[index].innerText ="₹" + total;
        subtotal += total;
    });
    let delivery = 0;
    if(subtotal > 0 && subtotal < 500){
        delivery = 50;
    }
    let grandTotal =subtotal + delivery;
    subtotalText.innerText ="Subtotal : ₹" + subtotal;
    deliveryText.innerText ="Delivery Charge : ₹" + delivery;
    grandText.innerText ="Grand Total : ₹" + grandTotal;
    hiddenTotal.value =
    grandTotal;
}





FoodOrderServlet.java
import java.io.*;
import javax.servlet.*;
import javax.servlet.http.*;
public class FoodOrderServlet extends HttpServlet {
    public void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
        String burger =request.getParameter("burger");
        String pizza =request.getParameter("pizza");
        String pasta = request.getParameter("pasta");
        String fries =request.getParameter("fries");
        String sandwich =request.getParameter("sandwich");
        String drink = request.getParameter("drink");
        String total =request.getParameter("grandTotal");
        request.setAttribute("burger", burger);
        request.setAttribute("pizza", pizza);
        request.setAttribute("pasta", pasta);
        request.setAttribute("fries", fries);
        request.setAttribute("sandwich", sandwich);
        request.setAttribute("drink", drink);
        request.setAttribute("total", total);
        RequestDispatcher rd =request.getRequestDispatcher("summary.jsp");
        rd.forward(request,response);
    }
}



