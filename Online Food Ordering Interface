<td>120</td>
<td>
<input type="number" min="0" value="0" name="burger" class="qty" data-price="120">
</td>
<td class="itemTotal">₹0</td>
</tr>
<tr>
<td>Pizza</td>
<td>250</td>
<td>
<input type="number" min="0" value="0" name="pizza" class="qty" data-price="250">
</td>
<td class="itemTotal">₹0</td>
</tr>
<tr>
<td>Pasta</td>
<td>180</td>
<td>
<input type="number" min="0" value="0" name="pasta" class="qty" data-price="180">
</td>
<td class="itemTotal">₹0</td>
</tr>
<tr>
<td>French Fries</td>
<td>100</td>
<td>
<input type="number" min="0" value="0" name="fries" class="qty" data-price="100">
</td>
<td class="itemTotal">₹0</td>
</tr>
<tr>
<td>Sandwich</td>
<td>150</td>
<td>
<input type="number" min="0" value="0" name="sandwich" class="qty" data-price="150">
</td>
<td class="itemTotal">₹0</td>
</tr>
<tr>
<td>Cold Drink</td>
<td>80</td>
<td>
<input type="number" min="0" value="0" name="drink" class="qty" data-price="80">
</td>
