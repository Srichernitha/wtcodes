<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
      content="width=device-width, initial-scale=1.0">

<title>Payroll Processing</title>

<link rel="stylesheet"
      href="style.css">

</head>

<body>

<div class="container">

<div class="card">

<h1>Payroll Processing System</h1>

<form action="payroll"
      method="post"
      onsubmit="return validateForm()">

<input type="text"
       id="employeeName"
       name="employeeName"
       placeholder="Enter Employee Name">

<input type="number"
       id="basicSalary"
       name="basicSalary"
       placeholder="Enter Basic Salary">

<input type="number"
       id="hra"
       name="hra"
       placeholder="Enter HRA Percentage">

<input type="number"
       id="bonus"
       name="bonus"
       placeholder="Enter Bonus Amount">

<button type="submit">
Generate Payroll
</button>

</form>

<p id="error"></p>

</div>

</div>

<script src="script.js"></script>

</body>
</html>




