script.js
function validateForm(){

    let employeeName =
    document.getElementById("employeeName")
    .value;

    let basicSalary =
    document.getElementById("basicSalary")
    .value;

    let hra =
    document.getElementById("hra")
    .value;

    let bonus =
    document.getElementById("bonus")
    .value;

    let error =
    document.getElementById("error");

    error.innerHTML = "";

    if(employeeName.trim() === ""){

        error.innerHTML =
        "Employee name is required";

        return false;
    }

    if(basicSalary <= 0
       || hra < 0
       || bonus < 0){

        error.innerHTML =
        "Please enter valid salary details";

        return false;
    }

    return true;
}



PayrollServlet.java
import java.io.*;
import javax.servlet.*;
import javax.servlet.http.*;

public class PayrollServlet extends HttpServlet {

    public void doPost(HttpServletRequest request,
                       HttpServletResponse response)
            throws ServletException, IOException {

        String employeeName =
                request.getParameter("employeeName");

        double basicSalary =
                Double.parseDouble(
                request.getParameter("basicSalary"));

        double hraPercentage =
                Double.parseDouble(
                request.getParameter("hra"));

        double bonus =
                Double.parseDouble(
                request.getParameter("bonus"));

        double hraAmount =
                (basicSalary * hraPercentage) / 100;

        double grossSalary =
                basicSalary + hraAmount + bonus;

        request.setAttribute("employeeName",
                             employeeName);

        request.setAttribute("basicSalary",
                             basicSalary);

        request.setAttribute("hraPercentage",
                             hraPercentage);

        request.setAttribute("hraAmount",
                             hraAmount);

        request.setAttribute("bonus",
                             bonus);

        request.setAttribute("grossSalary",
                             grossSalary);

        RequestDispatcher rd =
                request.getRequestDispatcher(
                        "payroll.jsp"
                );

        rd.forward(request,response);
    }
}




