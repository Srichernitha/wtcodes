<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
      content="width=device-width, initial-scale=1.0">

<title>Number Statistics Table</title>

<link rel="stylesheet"
      href="style.css">

</head>

<body>

<div class="container">

<div class="card">

<h1>Number Statistics Generator</h1>

<div class="input-section">

<input type="number"
       id="maxNumber"
       placeholder="Enter Maximum Number">

<button onclick="generateTable()">
Generate Table
</button>

</div>

<table>

<thead>

<tr>

<th>Number</th>
<th>Square</th>
<th>Cube</th>
<th>Even / Odd</th>

</tr>

</thead>

<tbody id="tableBody">

</tbody>

</table>

</div>

</div>

<script src="script.js"></script>

</body>
</html>



style.css
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#ff9a9e,#fad0c4);
    padding:30px;
}

.card{
    width:950px;
    background:white;
    padding:35px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,0.2);
}

h1{
    text-align:center;
    margin-bottom:25px;
    color:#333;
}

.input-section{
    display:flex;
    gap:15px;
    margin-bottom:25px;
}

input{
    flex:1;
    padding:14px;
    border-radius:10px;
    border:1px solid #ccc;
    outline:none;
}

button{
    padding:14px 25px;
    border:none;
    border-radius:10px;
    background:#ff6b6b;
    color:white;
    font-size:16px;
    cursor:pointer;
}

button:hover{
    opacity:0.9;
}

table{
    width:100%;
    border-collapse:collapse;
}

th{
    background:#ff6b6b;
    color:white;
    padding:15px;
}

td{
    padding:15px;
    text-align:center;
    border-bottom:1px solid #ddd;
}

tr:hover{
    background:#f5f5f5;
}

.even{
    background:#d4edda;
}

.odd{
    background:#fff;
}




script.js
function generateTable(){

    let maxNumber =
    parseInt(
    document.getElementById("maxNumber")
    .value);

    let tableBody =
    document.getElementById("tableBody");

    tableBody.innerHTML = "";

    if(isNaN(maxNumber)
       || maxNumber <= 0){

        alert(
        "Please enter a valid number"
        );

        return;
    }

    for(let i = 1;
        i <= maxNumber;
        i++){

        let square =
        i * i;

        let cube =
        i * i * i;

        let type =
        i % 2 === 0
        ? "Even"
        : "Odd";

        let row =
        document.createElement("tr");

        if(i % 2 === 0){

            row.classList.add("even");
        }

        else{

            row.classList.add("odd");
        }

        row.innerHTML =

        `<td>${i}</td>

         <td>${square}</td>

         <td>${cube}</td>

         <td>${type}</td>`;

        tableBody.appendChild(row);
    }
}
