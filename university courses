script.js
const tableBody =
document.getElementById("courseTable");
const semesterFilter =
document.getElementById("semesterFilter");
const searchBox =
document.getElementById("searchBox");
let allCourses = [];
fetch("courses.xml")
.then(response => response.text())
.then(data => {
    const parser = new DOMParser();
    const xml =
    parser.parseFromString(data,"text/xml");
    const courses =
    xml.getElementsByTagName("course");
    for(let course of courses){
        let courseData = {
            code:
            course.getElementsByTagName("code")[0]
            .textContent,
            title:
            course.getElementsByTagName("title")[0]
            .textContent,
            credits:
            course.getElementsByTagName("credits")[0]
            .textContent,
            instructor:
            course.getElementsByTagName("instructor")[0]
            .textContent,
            semester:
            course.getElementsByTagName("semester")[0]
            .textContent
        };
        allCourses.push(courseData);
    }
    displayCourses(allCourses);
});
function displayCourses(courses){
    tableBody.innerHTML = "";
    courses.forEach(course => {
        let row =
        `<tr>
            <td>${course.code}</td>
            <td>${course.title}</td>
            <td>${course.credits}</td>
            <td>${course.instructor}</td>
            <td>${course.semester}</td>
        </tr>`;
        tableBody.innerHTML += row;
    });
}
semesterFilter.addEventListener("change",
function(){
    filterCourses();
});
searchBox.addEventListener("keyup",
function(){
    filterCourses();
});
function filterCourses(){
    let semester =
    semesterFilter.value;
    let search =
    searchBox.value.toLowerCase();
    let filtered =
    allCourses.filter(course => {
        let matchSemester =
        semester === "All"
        || course.semester === semester;
        let matchSearch =
        course.title.toLowerCase()
        .includes(search);
        return matchSemester
               && matchSearch;
    });
    displayCourses(filtered);
}
