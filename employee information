style.css
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#89f7fe,#66a6ff);
    padding:30px;
}

.card{
    width:1000px;
    background:white;
    padding:35px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,0.2);
}

h1{
    text-align:center;
    margin-bottom:25px;
    color:#333;
}

.buttons{
    display:flex;
    justify-content:center;
    gap:20px;
    margin-bottom:25px;
}

button{
    padding:12px 20px;
    border:none;
    border-radius:10px;
    background:#4a69bd;
    color:white;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    transform:translateY(-2px);
}

table{
    width:100%;
    border-collapse:collapse;
}

th{
    background:#4a69bd;
    color:white;
    padding:15px;
}

td{
    padding:15px;
    text-align:center;
    border-bottom:1px solid #ddd;
}

tr:hover{
    background:#f5f5f5;
}






script.js
const employeeTable =
document.getElementById("employeeTable");

const sortSalaryBtn =
document.getElementById("sortSalary");

const filterExperienceBtn =
document.getElementById("filterExperience");

const showAllBtn =
document.getElementById("showAll");

let allEmployees = [];

fetch("employees.xml")

.then(response => response.text())

.then(data => {

    const parser = new DOMParser();

    const xml =
    parser.parseFromString(data,"text/xml");

    const employees =
    xml.getElementsByTagName("employee");

    for(let employee of employees){

        let employeeData = {

            id:
            employee.getElementsByTagName("id")[0]
            .textContent,

            name:
            employee.getElementsByTagName("name")[0]
            .textContent,

            department:
            employee.getElementsByTagName("department")[0]
            .textContent,

            salary:
            parseInt(
            employee.getElementsByTagName("salary")[0]
            .textContent),

            experience:
            parseInt(
            employee.getElementsByTagName("experience")[0]
            .textContent)
        };

        allEmployees.push(employeeData);
    }

    displayEmployees(allEmployees);
});

function displayEmployees(employees){

    employeeTable.innerHTML = "";

    employees.forEach(employee => {

        let row =

        `<tr>

            <td>${employee.id}</td>

            <td>${employee.name}</td>

            <td>${employee.department}</td>

            <td>₹${employee.salary}</td>

            <td>${employee.experience} Years</td>

        </tr>`;

        employeeTable.innerHTML += row;
    });
}

sortSalaryBtn.addEventListener("click",()=>{

    let sortedEmployees =
    [...allEmployees].sort(
        (a,b)=> b.salary - a.salary
    );

    displayEmployees(sortedEmployees);
});

filterExperienceBtn.addEventListener("click",()=>{

    let filteredEmployees =
    allEmployees.filter(
        employee => employee.experience > 5
    );

    displayEmployees(filteredEmployees);
});

showAllBtn.addEventListener("click",()=>{

    displayEmployees(allEmployees);
});
