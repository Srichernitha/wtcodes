style.css
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial;
}

body{
    background:#f4f4f4;
    color:#333;
}

nav{
    background:#222;
    color:white;
    padding:20px 40px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

nav h1{
    font-size:32px;
}

nav ul{
    display:flex;
    list-style:none;
    gap:20px;
}

nav ul li{
    cursor:pointer;
    padding:10px 15px;
    border-radius:8px;
    transition:0.3s;
}

nav ul li:hover{
    background:#444;
}

.featured{
    padding:40px;
}

.featured h2{
    margin-bottom:20px;
}

.featured-card{
    background:white;
    padding:30px;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,0.1);
}

.featured-card h3{
    margin-bottom:15px;
    color:#e74c3c;
}

.trending{
    padding:0 40px 40px;
}

.trending h2{
    margin-bottom:20px;
}

.trending-container{
    display:flex;
    gap:20px;
    flex-wrap:wrap;
}

.trend-box{
    flex:1;
    min-width:200px;
    background:#ff7675;
    color:white;
    padding:20px;
    border-radius:15px;
    text-align:center;
    font-weight:bold;
}

.articles-section{
    padding:0 40px 40px;
}

.articles-section h2{
    margin-bottom:20px;
}

.articles-container{
    display:grid;
    grid-template-columns:
    repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.article-card{
    background:white;
    padding:25px;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,0.1);
    transition:0.3s;
}

.article-card:hover{
    transform:translateY(-8px);
}

.article-card h3{
    margin-bottom:15px;
    color:#2d3436;
}

.article-card p{
    margin-bottom:15px;
    line-height:1.5;
}

.article-card span{
    display:inline-block;
    padding:8px 15px;
    background:#0984e3;
    color:white;
    border-radius:8px;
}

@media(max-width:768px){

    nav{
        flex-direction:column;
        gap:15px;
    }

    nav ul{
        flex-wrap:wrap;
        justify-content:center;
    }
}




script.js
function filterArticles(category){

    const articles =
    document.querySelectorAll(
    ".article-card"
    );

    articles.forEach(article => {

        if(category === "All"){

            article.style.display =
            "block";
        }

        else if(
        article.dataset.category
        === category){

            article.style.display =
            "block";
        }

        else{

            article.style.display =
            "none";
        }
    });
}
