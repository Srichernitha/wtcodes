style.css
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#667eea,#764ba2);
    padding:30px;
}

.card{
    width:1000px;
    background:white;
    padding:35px;
    border-radius:20px;
    box-shadow:0 10px 30px rgba(0,0,0,0.2);
}

h1{
    text-align:center;
    margin-bottom:25px;
    color:#333;
}

table{
    width:100%;
    border-collapse:collapse;
}

th{
    background:#6c5ce7;
    color:white;
    padding:15px;
}

td{
    padding:15px;
    text-align:center;
    border-bottom:1px solid #ddd;
}

input{
    width:80px;
    padding:10px;
    border-radius:8px;
    border:1px solid #ccc;
    text-align:center;
}

.summary{
    margin-top:30px;
    text-align:right;
}

.summary h2{
    margin:15px 0;
    color:#444;
}

tr:hover{
    background:#f5f5f5;
}




Script.js
const qtyInputs =
document.querySelectorAll(".qty");

const subtotalFields =
document.querySelectorAll(".subtotal");

const grandTotalField =
document.getElementById("grandTotal");

const discountField =
document.getElementById("discount");

const finalAmountField =
document.getElementById("finalAmount");

qtyInputs.forEach((input,index)=>{

    input.addEventListener("input",()=>{

        calculateCart();
    });
});

function calculateCart(){

    let grandTotal = 0;

    qtyInputs.forEach((input,index)=>{

        let quantity =
        parseInt(input.value) || 0;

        let price =
        parseInt(input.dataset.price);

        let subtotal =
        quantity * price;

        subtotalFields[index].innerHTML =
        "₹" + subtotal;

        grandTotal += subtotal;
    });

    let discount = 0;

    if(grandTotal > 2000){

        discount =
        grandTotal * 0.10;
    }

    let finalAmount =
    grandTotal - discount;

    grandTotalField.innerHTML =
    "Grand Total : ₹"
    + grandTotal.toFixed(2);

    discountField.innerHTML =
    "Discount : ₹"
    + discount.toFixed(2);

    finalAmountField.innerHTML =
    "Final Payable Amount : ₹"
    + finalAmount.toFixed(2);
}
