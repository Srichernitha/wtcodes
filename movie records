    color:#155724;
    font-weight:bold;
}





script.js
const movieTable =
document.getElementById("movieTable");

const genreFilter =
document.getElementById("genreFilter");

let allMovies = [];

fetch("movies.xml")

.then(response => response.text())

.then(data => {

    const parser = new DOMParser();

    const xml =
    parser.parseFromString(data,"text/xml");

    const movies =
    xml.getElementsByTagName("movie");

    for(let movie of movies){

        let movieData = {

            title:
            movie.getElementsByTagName("title")[0]
            .textContent,

            genre:
            movie.getElementsByTagName("genre")[0]
            .textContent,

            releaseYear:
            movie.getElementsByTagName("releaseYear")[0]
            .textContent,

            rating:
            parseFloat(
            movie.getElementsByTagName("rating")[0]
            .textContent),

            language:
            movie.getElementsByTagName("language")[0]
            .textContent
        };

        allMovies.push(movieData);
    }

    displayMovies(allMovies);
});

function displayMovies(movies){

    movieTable.innerHTML = "";

    movies.forEach(movie => {

        let highlightClass = "";

        if(movie.rating >= 8){

            highlightClass = "highlight";
        }

        let row =

        `<tr class="${highlightClass}">

            <td>${movie.title}</td>

            <td>${movie.genre}</td>

            <td>${movie.releaseYear}</td>

            <td>${movie.rating}</td>

            <td>${movie.language}</td>

        </tr>`;

        movieTable.innerHTML += row;
    });
}

genreFilter.addEventListener("change",()=>{

    let selectedGenre =
    genreFilter.value;

    if(selectedGenre === "All"){

        displayMovies(allMovies);
    }

    else{

        let filteredMovies =
        allMovies.filter(movie =>
            movie.genre === selectedGenre
        );

        displayMovies(filteredMovies);
    }
});
