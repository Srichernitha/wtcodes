<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
      content="width=device-width, initial-scale=1.0">

<title>University Admission</title>

<link rel="stylesheet"
      href="style.css">

</head>

<body>

<div class="container">

<div class="card">

<h1>University Admission System</h1>

<form action="admission"
      method="post"
      oninput="calculateResult()"
      onsubmit="return validateForm()">

<input type="text"
       id="name"
       name="name"
       placeholder="Enter Student Name"
       required>

<input type="number"
       id="physics"
       name="physics"
       placeholder="Physics Marks"
       required>

<input type="number"
       id="chemistry"
       name="chemistry"
       placeholder="Chemistry Marks"
       required>

<input type="number"
       id="maths"
       name="maths"
       placeholder="Mathematics Marks"
       required>

<input type="number"
       id="entrance"
       name="entrance"
       placeholder="Entrance Exam Score"
       required>

<div class="preview">

<h2 id="total">
Total : 0
</h2>

<h2 id="percentage">
Percentage : 0%
</h2>

<h2 id="eligibility">
Eligibility : Not Eligible
</h2>

</div>

<button type="submit">
Check Admission
</button>

</form>

<p id="error"></p>

</div>

</div>

<script src="script.js"></script>

</body>
</html>




