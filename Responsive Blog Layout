style.css
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial;
}

body{
    background:#f4f4f4;
    color:#333;
    transition:0.3s;
}

header{
    background:#4a69bd;
    color:white;
    padding:20px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

header h1{
    font-size:32px;
}

#darkModeToggle{
    padding:10px 18px;
    border:none;
    border-radius:8px;
    background:white;
    color:#4a69bd;
    cursor:pointer;
    font-weight:bold;
}

nav{
    background:#333;
}

nav ul{
    display:flex;
    list-style:none;
    justify-content:center;
}

nav ul li{
    margin:0 15px;
}

nav ul li a{
    color:white;
    text-decoration:none;
    display:block;
    padding:15px;
}

nav ul li a:hover{
    background:#555;
}

.container{
    display:grid;
    grid-template-columns:3fr 1fr;
    gap:25px;
    padding:30px;
}

main{
    display:flex;
    flex-direction:column;
    gap:25px;
}

.blog-card{
    background:white;
    padding:25px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

.blog-card h2{
    margin-bottom:10px;
    color:#4a69bd;
}

.date{
    margin-bottom:15px;
    color:gray;
}

aside{
    background:white;
    padding:25px;
    border-radius:15px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
    height:fit-content;
}

aside h2{
    margin-bottom:15px;
    color:#4a69bd;
}

aside ul{
    list-style:none;
}

aside ul li{
    padding:10px 0;
    border-bottom:1px solid #ddd;
}

footer{
    background:#4a69bd;
    color:white;
    text-align:center;
    padding:20px;
    margin-top:20px;
}

.dark-mode{
    background:#1e1e1e;
    color:white;
}

.dark-mode .blog-card,
.dark-mode aside{
    background:#2c2c2c;
    color:white;
}

.dark-mode nav{
    background:#111;
}

.dark-mode nav ul li a:hover{
    background:#222;
}

.dark-mode #darkModeToggle{
    background:#333;
    color:white;
}

@media(max-width:768px){

    .container{
        grid-template-columns:1fr;
    }

    nav ul{
        flex-direction:column;
        align-items:center;
    }

    header{
        flex-direction:column;
        gap:15px;
    }
}




script.js
const darkModeToggle =
document.getElementById(
"darkModeToggle"
);

if(localStorage.getItem("theme")
   === "dark"){

    document.body.classList.add(
        "dark-mode"
    );
}

darkModeToggle.addEventListener(
"click",()=>{

    document.body.classList.toggle(
        "dark-mode"
    );

    if(document.body.classList.contains(
       "dark-mode")){

        localStorage.setItem(
            "theme",
            "dark"
        );
    }

    else{

        localStorage.setItem(
            "theme",
            "light"
        );
    }
});


























