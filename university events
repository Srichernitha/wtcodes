script.js
const eventTable =
document.getElementById("eventTable");

const searchBox =
document.getElementById("searchBox");

let allEvents = [];

fetch("events.xml")

.then(response => response.text())

.then(data => {

    const parser = new DOMParser();

    const xml =
    parser.parseFromString(data,"text/xml");

    const events =
    xml.getElementsByTagName("event");

    for(let event of events){

        let eventData = {

            name:
            event.getElementsByTagName("name")[0]
            .textContent,

            department:
            event.getElementsByTagName("department")[0]
            .textContent,

            date:
            event.getElementsByTagName("date")[0]
            .textContent,

            venue:
            event.getElementsByTagName("venue")[0]
            .textContent,

            organizer:
            event.getElementsByTagName("organizer")[0]
            .textContent
        };

        allEvents.push(eventData);
    }

    sortEventsByDate();

    displayEvents(allEvents);
});

function sortEventsByDate(){

    allEvents.sort((a,b)=>{

        return new Date(a.date)
             - new Date(b.date);
    });
}

function displayEvents(events){

    eventTable.innerHTML = "";

    events.forEach(event => {

        let row =

        `<tr>

            <td>${event.name}</td>

            <td>${event.department}</td>

            <td>${event.date}</td>

            <td>${event.venue}</td>

            <td>${event.organizer}</td>

        </tr>`;

        eventTable.innerHTML += row;
    });
}

searchBox.addEventListener("keyup",()=>{

    let searchText =
    searchBox.value.toLowerCase();

    let filteredEvents =
    allEvents.filter(event =>

        event.department
        .toLowerCase()
        .includes(searchText)
    );

    displayEvents(filteredEvents);
});
